# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 실시간 전사(STT) 모델. gpt-realtime-whisper(스트리밍) 권장
#  대안: gpt-4o-transcribe(고정확, server VAD), gpt-4o-mini-transcribe(저비용)
TRANSCRIBE_MODEL=gpt-realtime-whisper

# 번역 목표 언어 기본값 (ko=한국어, en, ja, es ...)
TARGET_LANG=ko

# 번역/다듬기 모델 (gpt-5-mini / gpt-4.1-mini / gpt-5-nano)
REFINE_MODEL=gpt-5-mini

# 서버 포트 (Render 는 자동 주입하므로 배포 시 설정 불필요)
PORT=3000

# 세션 영속화: MongoDB Atlas 연결 문자열.
#  - 설정하면 Mongo 에 저장(배포/재시작에도 유지). 비워두면 로컬 data/sessions.json 파일 사용.
#  예: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=kac_translator
