# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 모델(TRANSCRIBE/TRANSLATE/REFINE)은 server.js 에 코드 고정 → 환경변수 불필요.

# 번역 목표 언어 기본값 (ko=한국어, en, ja, es ...)
TARGET_LANG=ko

# 인증(데스크톱 호스트만 보호, 모바일 QR 뷰어는 공개).
#  - 관리자 계정: 아래 ID/비번으로 로그인. 일반 사용자는 관리자 페이지에서 생성.
#  - 미설정 시 기본값 admin/admin (로컬 개발용) — 운영 전 반드시 변경.
ADMIN_ID=admin
ADMIN_PASSWORD=admin
# 로그인 쿠키 서명 키(임의의 긴 무작위 문자열). 비우면 ADMIN_PASSWORD 에서 자동 파생.
AUTH_SECRET=

# 토큰 비용 단가(USD per 1M tokens). 관리자 페이지 '총 토큰 사용 비용' 계산용.
#  사용 모델(REFINE_MODEL) 실제 가격에 맞춰 조정. 미설정 시 아래 기본값.
PRICE_IN_PER_1M=0.25
PRICE_OUT_PER_1M=2

# 서버 포트 (Render 는 자동 주입하므로 배포 시 설정 불필요)
PORT=3000

# 세션 영속화: MongoDB Atlas 연결 문자열. 비우면 로컬 data/sessions.json 파일 사용.
#  - DB 이름은 server.js 에 기본값(kac_translator) 고정. 바꾸려면 MONGODB_DB 로 덮어쓰기 가능.
#  예: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
