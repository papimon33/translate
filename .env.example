# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 모델(TRANSCRIBE/TRANSLATE/REFINE)은 server.js 에 코드 고정 → 환경변수 불필요.

# 번역 목표 언어 기본값 (ko=한국어, en, ja, es ...)
TARGET_LANG=ko

# 인증(데스크톱 호스트만 보호, 모바일 QR 뷰어는 공개).
#  - 관리자 계정: 아래 ID/비번으로 로그인. 일반 사용자는 관리자 페이지에서 생성.
#  - 미설정 시 기본값 admin/admin (로컬 개발용) — 운영 전 반드시 변경.
ADMIN_ID=admin
ADMIN_PASSWORD=admin
# 로그인 쿠키 서명 키(임의의 긴 무작위 문자열). 비우면 ADMIN_PASSWORD 에서 자동 파생.
AUTH_SECRET=

# 사용 비용 단가(USD per minute, 파이프라인별). 관리자 페이지 '총 사용 비용' 계산용.
#  호스트 사용(녹음) 시간 × 단가. 미설정 시 아래 기본값.
PRICE_TRANSLATE_PER_MIN=0.034
PRICE_WHISPER_PER_MIN=0.017

# Deepgram Nova-3 테스트 모드용 키(선택). 없으면 deepgram 파이프라인 비활성.
DEEPGRAM_API_KEY=

# Soniox stt-rt-v5 테스트 모드용 키(선택). 없으면 soniox 파이프라인 비활성.
SONIOX_API_KEY=

# Cartesia Sonic 실시간 TTS용 키(선택). 없으면 음성 출력(TTS) 비활성.
CARTESIA_API_KEY=

# 서버 포트 (Render 는 자동 주입하므로 배포 시 설정 불필요)
PORT=3000

# 세션 영속화: MongoDB Atlas 연결 문자열. 비우면 로컬 data/sessions.json 파일 사용.
#  - DB 이름은 server.js 에 기본값(kac_translator) 고정. 바꾸려면 MONGODB_DB 로 덮어쓰기 가능.
#  예: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# 데스크톱 앱(Electron) 다운로드 — 프로필 → '데스크톱 앱' 모달의 다운로드 버튼이 사용.
#  · GitHub Actions(desktop-build.yml)가 설치본(.exe)을 만들어 Release 로 올린다.
#  · 비공개 repo 면 서버가 이 토큰으로 에셋을 받아 사용자에게 스트리밍(사용자 GitHub 인증 불필요).
#    Contents(read) 권한의 fine-grained PAT 또는 classic repo 스코프 토큰.
#  · 공개 repo 로 바꾸면 토큰 없이도 GitHub 다운로드 URL 로 바로 리다이렉트된다.
GITHUB_TOKEN=
#  대상 repo(owner/name). 기본값은 코드에 고정(papimon33/translate).
DESKTOP_REPO=
#  GitHub 을 거치지 않고 특정 주소(사내 서버·S3 등)로 바로 보내려면 여기에 exe URL 을 지정.
DESKTOP_DOWNLOAD_URL=
