# =============================================================================
#  KAC Translator — 환경변수 템플릿 (.env.example, 커밋됨 — 비밀값 넣지 말 것)
#  로컬: 이 파일을 .env 로 복사해 값 채움 (.env 는 gitignore).
#  운영: 파일이 아니라 호스팅 플랫폼의 env 주입 기능에 입력
#        (Render 대시보드 / Fly secrets / Railway Variables / docker --env-file 등).
# =============================================================================

# ── 필수: 실시간 파이프라인 키 ────────────────────────────────────────────────
# OpenAI (번역/다듬기). ⚠ 호출 시 항상 과금 — 테스트 세션은 끝나고 삭제.
OPENAI_API_KEY=sk-...
# Soniox stt-rt-v5 (실시간 STT+번역). 없으면 soniox 파이프라인 비활성.
SONIOX_API_KEY=
# Cartesia Sonic 실시간 TTS. 없으면 음성 출력(TTS) 비활성.
CARTESIA_API_KEY=

# ── 데이터 저장소 (개발/운영 분리 지점) ──────────────────────────────────────
# MongoDB Atlas 연결 문자열. 비우면 로컬 data/*.json 파일 모드.
#  예: mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# DB 이름. 비우면 코드 기본값 kac_translator (운영은 비워 둔다).
#  ★ 로컬 개발에서 운영 클러스터 URI 를 쓸 땐 반드시 kac_translator_dev 등
#    다른 이름을 지정해 운영 데이터 오염을 막는다.
MONGODB_DB=

# ── 인증 / 관리자 ────────────────────────────────────────────────────────────
# 관리자 계정. 미설정 시 기본값 admin/admin (로컬 개발용) — 운영 전 반드시 변경.
# 일반 사용자 계정은 관리자 페이지에서 생성.
ADMIN_ID=admin
ADMIN_PASSWORD=admin
# 로그인 쿠키 서명 키(임의의 긴 무작위 문자열). 비우면 ADMIN_PASSWORD 에서 파생.
AUTH_SECRET=
# 관리자 2FA(TOTP) 시크릿(선택). 설정 시 env 가 우선, 관리자 페이지에서 변경 불가.
ADMIN_TOTP_SECRET=

# ── 서버 동작 ────────────────────────────────────────────────────────────────
# 포트. Render 등 PaaS 는 자동 주입하므로 배포 시 설정 불필요.
PORT=3000
# 번역 목표 언어 기본값 (ko, en, ja, es ...).
TARGET_LANG=ko
# production 에서만 HTTPS 강제·기본 비밀번호 차단 등 보안 검사 활성.
NODE_ENV=
# production 인데도 http 로 기동해야 할 때만 1 (검증 환경 등).
ALLOW_INSECURE=
# http→https 301 리다이렉트(프록시 뒤, x-forwarded-proto 기준). 1 이면 활성.
FORCE_HTTPS=
# 리다이렉트에 쓸 고정 호스트(오픈 리다이렉트 방지). 예: translate.example.com
PUBLIC_HOST=

# ── 파일 모드 저장 암호화 (선택) ─────────────────────────────────────────────
# 설정 시 data/*.json 을 AES-256-GCM 으로 암호화 저장(임의의 긴 문자열).
DATA_KEY=

# ── 벤더 사용량 조회용 관리자 키 (선택, 관리자 페이지 '총 비용') ──────────────
# OpenAI 조직 비용 조회. sk-admin-… (일반 API 키와 다름).
OPENAI_ADMIN_API_KEY=
# Cartesia 크레딧 조회. sk_car_admin_…
CARTESIA_ADMIN_API_KEY=

# ── 비용 단가 (관리자 페이지 비용 계산용, USD/분) ────────────────────────────
PRICE_TRANSLATE_PER_MIN=0.034
PRICE_WHISPER_PER_MIN=0.017

# ── 데스크톱 앱 다운로드 (선택) ──────────────────────────────────────────────
#  · GitHub Actions(desktop-build.yml)가 설치본(.exe)을 Release 로 올린다.
#  · 비공개 repo 면 서버가 이 토큰으로 에셋을 받아 스트리밍(Contents:read PAT).
#  · 공개 repo 면 토큰 없이 GitHub 다운로드 URL 로 바로 리다이렉트.
GITHUB_TOKEN=
# 대상 repo(owner/name). 비우면 코드 기본값 papimon33/translate.
DESKTOP_REPO=
# GitHub 대신 특정 주소(사내 서버·S3)로 바로 보내려면 exe URL 지정.
DESKTOP_DOWNLOAD_URL=

# ── 테스트/개발 전용 오버라이드 (평소엔 비워 둔다) ───────────────────────────
# 실 엔진 대신 로컬 fake 서버로 붙일 때 사용(무과금 테스트). 예: ws://localhost:9xxx
SONIOX_WS_URL=
CARTESIA_TTS_WS_URL=
# 파일 모드 데이터 디렉터리 격리(테스트). 비우면 ./data.
DATA_DIR=

# 모델(TRANSCRIBE/TRANSLATE/REFINE)은 server.js 에 코드 고정 → 환경변수 불필요.
